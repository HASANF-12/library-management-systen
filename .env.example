# Database (Neon Postgres – use pooler endpoint for serverless/Vercel)
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"

# Auth.js v5 (NextAuth) – required for sessions/tokens
AUTH_SECRET="generate-with-openssl-rand-base64-32"
# Callback URL base (local dev vs production)
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# AI – Groq (optional; free tier at https://console.groq.com/keys)
# GROQ_API_KEY=""
# GROQ_MODEL="llama-3.1-8b-instant"
